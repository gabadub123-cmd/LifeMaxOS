# ===========================
# LIFEMAX OS — .gitignore
# Vite + React + Supabase + Node.js
# ===========================

# ----- Dependencies -----
node_modules/

# ----- Build output -----
dist/
dist-ssr/
build/
.vite/

# ----- Environment variables -----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- macOS system files -----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ----- Windows system files -----
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- Linux system files -----
*~

# ----- Editor / IDE -----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ----- Vite -----
*.local

# ----- Coverage & testing -----
coverage/
.nyc_output/

# ----- Misc caches -----
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# ----- Supabase local -----
supabase/.temp/
supabase/.branches/

# ----- Netlify -----
.netlify/
